_name=eww
pkgname=eww-myfixes-git
pkgver=0.6.0
pkgrel=1
pkgdesc="Fork of eww"
url='https://github.com/liegle/eww'
arch=(x86_64)
license=(MIT)
makedepends=(cargo git)
depends=(libdbusmenu-gtk3 gtk3 gtk-layer-shell)
provides=(eww)
conflicts=(eww)
options=(!strip !debug)
source=(
    "git+$url#branch=master"
)
b2sums=('SKIP')

prepare() {
    cd $_name
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd $_name
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

package() {
    cd $_name
    install -vDm644 LICENSE -t "$pkgdir/usr/share/licenses/$_name/"
    install -vd "$pkgdir/etc/xdg/$_name/"
    cp -vr examples/eww-bar "$pkgdir/etc/xdg/$_name/"
    install -vDm755 target/release/$_name -t "$pkgdir/usr/bin/"
}
